@baseUrl = http://localhost:8000
@accessToken = {{login.response.body.access_token}}

# ─────────────────────────────────────────────────────────────────────────────
# Sound Necklace (Colar de Sons) — /api/colar
#
# All routes below are STUBS returning 501 until each resource issue lands
# (sessions ENG-260, audio bucket ENG-261, voice answers, artifacts, …). They
# exist so the emitted OpenAPI carries the full contract and the SPA can generate
# its TypeScript types:
#
#   # with the app running (uvicorn app.main:app):
#   npx openapi-typescript@7 http://localhost:8000/openapi.json -o colar-types.ts
#
#   # or straight from a dumped schema, no server needed:
#   uv run python -c "import json; from app.main import app; print(json.dumps(app.openapi()))" > openapi.json
#   npx openapi-typescript@7 openapi.json -o colar-types.ts
#
# Every colar schema is marked `x-stability: experimental` (provisional until the
# resource issues finalize each shape; the acousteme envelope is opaque per O8).
# ─────────────────────────────────────────────────────────────────────────────

### Login (sets the bearer token for the requests below)
# @name login
POST {{baseUrl}}/api/auth/login
Content-Type: application/json

{
  "username": "facilitator@example.com",
  "password": "password123"
}

### Sessions: list
GET {{baseUrl}}/api/colar/sessions
Authorization: Bearer {{accessToken}}

### Sessions: create
POST {{baseUrl}}/api/colar/sessions
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "audio_id": "aud_1",
  "project_id": "prj_1",
  "story_name": "O Conto do Boto",
  "story_slug": "conto-do-boto",
  "granularity_level": "media",
  "bead_sec": 0.5,
  "manifest_id": "fnv1a32:d31a8419",
  "pipeline_consent": true
}

### Sessions: autosave (version-guarded state envelope)
PUT {{baseUrl}}/api/colar/sessions/sess_1/state
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "schema_version": 1
}

### Lock: acquire / renew
PUT {{baseUrl}}/api/colar/sessions/sess_1/lock
Authorization: Bearer {{accessToken}}

### Bucket: list a project's audios
GET {{baseUrl}}/api/colar/projects/prj_1/audios
Authorization: Bearer {{accessToken}}

### Bucket: short-TTL signed URL for an audio (audit point)
GET {{baseUrl}}/api/colar/audios/aud_1/url
Authorization: Bearer {{accessToken}}
